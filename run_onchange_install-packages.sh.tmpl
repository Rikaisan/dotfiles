#!/bin/bash

PREFIX="[CHEZMOI]"


{{ if (or (eq .chezmoi.osRelease.id "arch") (eq .chezmoi.osRelease.idLike "arch")) -}}
# Install Git and Yay
if ! command -v yay &> /dev/null
then
    if ! command -v git &> /dev/null
    then
        echo "$PREFIX git could not be found, installing..."
        sudo pacman -Sy --needed --noconfirm git
    fi
    echo "$PREFIX yay could not be found, installing..."
    echo "$PREFIX yay could not be found, installing..."
    cd $(mktemp -d)    
    git clone https://aur.archlinux.org/yay.git
    cd yay
    makepkg -sic
    cd ~
fi

# Some default yay configs for ease of use
echo "$PREFIX Configuring yay..."
yay --save --answerdiff None --answerclean None --removemake

# Packages!
echo "$PREFIX Updating repos..."
yay -Sy

# TODO: Find a way to clean up this mess, which would probably need template functions or something similar

{{ $category := "essential" }}
echo "$PREFIX ---------- Start {{ $category }} install ----------"
{{ if (get (get .packages.arch $category) "native") }}
echo "$PREFIX Installing native packages (pacman)..."
sudo pacman -S --needed --noconfirm {{ range (get .packages.arch $category).native -}}{{ . }} {{ end }}
{{ end }}
{{ if (get (get .packages.arch $category) "aur") }}
echo "$PREFIX Installing aur packages (yay)..."
yay -S --noconfirm --needed {{ range (get .packages.arch $category).aur -}}{{ . }} {{ end }}
{{ end }}
{{ if (get (get .packages.arch $category) "flatpak") }}
echo "$PREFIX Installing flatpak packages..."
flatpak install flathub {{ range (get .packages.arch $category).flatpak -}}{{ . }} {{ end }}-y
{{ end }}

{{ if eq .chezmoi.osRelease.id "endeavouros" }}
{{ if .packages.arch.essential.endeavouros }}
echo "$PREFIX Installing EndeavourOS specific packages (yay)..."
yay -S --noconfirm --needed {{ range .packages.arch.essential.endeavouros -}}{{ . }} {{ end }}
{{ end }}
{{ end }}
echo "$PREFIX ---------- End {{ $category }} install ----------"

{{ $category = "extra" }}
echo "[{{ title $category }} packages]
{{ get .packages.arch $category | toYaml}}"
read -p "Do you want to install {{ $category }} packages?[Y/n] " -n 1 -r
echo    # (optional) move to a new line
if ! [[ $REPLY =~ ^[Nn]$ ]]
then
    echo "$PREFIX ---------- Start {{ $category }} install ----------"
    {{ if (get (get .packages.arch $category) "native") }}
    echo "$PREFIX Installing native packages (pacman)..."
    sudo pacman -S --needed --noconfirm {{ range (get .packages.arch $category).native -}}{{ . }} {{ end }}
    {{ end }}
    {{ if (get (get .packages.arch $category) "aur") }}
    echo "$PREFIX Installing aur packages (yay)..."
    yay -S --noconfirm --needed {{ range (get .packages.arch $category).aur -}}{{ . }} {{ end }}
    {{ end }}
    {{ if (get (get .packages.arch $category) "flatpak") }}
    echo "$PREFIX Installing flatpak packages..."
    flatpak install flathub {{ range (get .packages.arch $category).flatpak -}}{{ . }} {{ end }}-y
    {{ end }}
    echo "$PREFIX ---------- End {{ $category }} install ----------"
fi

{{ $category = "development" }}
echo "[{{ title $category }} packages]
{{ get .packages.arch $category | toYaml}}"
read -p "Do you want to install {{ $category }} packages?[Y/n] " -n 1 -r
echo    # (optional) move to a new line
if ! [[ $REPLY =~ ^[Nn]$ ]]
then
    echo "$PREFIX ---------- Start {{ $category }} install ----------"
    {{ if (get (get .packages.arch $category) "native") }}
    echo "$PREFIX Installing native packages (pacman)..."
    sudo pacman -S --needed --noconfirm {{ range (get .packages.arch $category).native -}}{{ . }} {{ end }}
    {{ end }}
    {{ if (get (get .packages.arch $category) "aur") }}
    echo "$PREFIX Installing aur packages (yay)..."
    yay -S --noconfirm --needed {{ range (get .packages.arch $category).aur -}}{{ . }} {{ end }}
    {{ end }}
    {{ if (get (get .packages.arch $category) "flatpak") }}
    echo "$PREFIX Installing flatpak packages..."
    flatpak install flathub {{ range (get .packages.arch $category).flatpak -}}{{ . }} {{ end }}-y
    {{ end }}
    echo "$PREFIX ---------- End {{ $category }} install ----------"
fi

{{ $category = "gaming" }}
echo "[{{ title $category }} packages]
{{ get .packages.arch $category | toYaml}}"
read -p "Do you want to install {{ $category }} packages?[Y/n] " -n 1 -r
echo    # (optional) move to a new line
if ! [[ $REPLY =~ ^[Nn]$ ]]
then
    echo "$PREFIX ---------- Start {{ $category }} install ----------"
    {{ if (get (get .packages.arch $category) "native") }}
    echo "$PREFIX Installing native packages (pacman)..."
    sudo pacman -S --needed --noconfirm {{ range (get .packages.arch $category).native -}}{{ . }} {{ end }}
    {{ end }}
    {{ if (get (get .packages.arch $category) "aur") }}
    echo "$PREFIX Installing aur packages (yay)..."
    yay -S --noconfirm --needed {{ range (get .packages.arch $category).aur -}}{{ . }} {{ end }}
    {{ end }}
    {{ if (get (get .packages.arch $category) "flatpak") }}
    echo "$PREFIX Installing flatpak packages..."
    flatpak install flathub {{ range (get .packages.arch $category).flatpak -}}{{ . }} {{ end }}-y
    {{ end }}
    echo "$PREFIX ---------- End {{ $category }} install ----------"
fi


{{ end -}}