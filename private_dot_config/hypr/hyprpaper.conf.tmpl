$wallpaperDir = $HOME/Pictures

$hpwp1 = $wallpaperDir/wallpaper0
preload = $hpwp1

{{ if eq .localEnv.workstation "desktop" -}}
$hpwp2 = $wallpaperDir/wallpaper1
preload = $hpwp2

wallpaper = DP-1,$hpwp1
wallpaper = HDMI-A-1,$hpwp2
{{ else -}}
wallpaper = eDP-1,$hpwp1
{{ end -}}

#enable splash text rendering over the wallpaper
splash = false

#fully disable ipc
# ipc = off

